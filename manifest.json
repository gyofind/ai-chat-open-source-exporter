{
  "manifest_version": 3,
  "name": "AI Chat Open Source Exporter",
  "version": "0.1.0",
  "description": "Export AI chat conversations locally to JSON, Markdown, or PDF. Open-source and privacy-focused.",
  "permissions": ["activeTab", "storage", "downloads"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon-light-theme-48.png",
    "theme_icons": [
      {
        "light": "icons/icon-light-theme-16.png",
        "dark": "icons/icon-dark-theme-16.png",
        "size": 16
      },
      {
        "light": "icons/icon-light-theme-32.png",
        "dark": "icons/icon-dark-theme-32.png",
        "size": 32
      },
      {
        "light": "icons/icon-light-theme-48.png",
        "dark": "icons/icon-dark-theme-48.png",
        "size": 48
      }
    ]
  },
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://chat.mistral.ai/*",
        "*://claude.ai/*",
        "*://gemini.google.com/*"
      ],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon-light-theme-16.png",
    "32": "icons/icon-light-theme-32.png",
    "48": "icons/icon-light-theme-48.png",
    "96": "icons/icon-light-theme-96.png"
  }
}