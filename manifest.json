{
  "manifest_version": 2,
  "name": "AI Chat Open Source Exporter",
  "version": "0.1.0",
  "description": "Export AI chat conversations locally to JSON, Markdown, or PDF. Open-source and privacy-focused.",
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },
  "permissions": ["activeTab", "storage", "downloads"],
  "background": {
    "scripts": ["src/background/background.js"]
  },
  "content_scripts": [
    {
      "matches": [
        "*://chat.mistral.ai/*",
        "*://claude.ai/*",
        "*://gemini.google.com/*"
      ],
      "js": ["src/lib/showdown.min.js", "src/lib/json-generator.js", "src/lib/pdf-generator.js", "src/content/content.js"]
    }
  ],
  "browser_action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": "icons/icon-48.png"
  }
}