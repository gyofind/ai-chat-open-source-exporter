{
  "manifest_version": 3,
  "name": "AI Chat Open Source Exporter",
  "version": "0.1.0",
  "description": "Export AI chat conversations locally to JSON, Markdown, or PDF. Open-source and privacy-focused.",
  "permissions": ["activeTab", "storage", "downloads"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon-48.png"
  },
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://chat.mistral.ai/*",
        "*://claude.ai/*",
        "*://gemini.google.com/*"
      ],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  }
}